# ── Database ──
DATABASE_URL=postgresql://compintel:compintel@localhost:5432/compintel

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider: "openai" | "anthropic" ──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=gpt-4o

# ── S3-compatible blob storage (Cloudflare R2 / AWS S3) ──
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=compintel-snapshots
S3_REGION=auto

# ── Email (Resend) ──
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=notifications@yourdomain.com

# ── App ──
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
